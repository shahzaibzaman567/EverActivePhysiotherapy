# API Serverless Function Environment Variables
# These are inherited from root .env and used in /api/index.js

# Database
MONGO_URI=mongodb://username:password@cluster-host:27017/?ssl=true&replicaSet=replica-set&authSource=admin

# Authentication
JWT_SECRET=your_very_secure_jwt_secret_key_here
JWT_EXPIRE=30d

# Email Service
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# Admin Account
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=secure_password_here

# AI Service
OPENROUTER_API_KEY=sk-or-v1-your-api-key

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Production Mode (set by vercel.json)
NODE_ENV=production
