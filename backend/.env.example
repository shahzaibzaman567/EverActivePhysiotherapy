# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5003
NODE_ENV=production

# ─── Database ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/everactive_physio?retryWrites=true&w=majority

# ─── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_at_least_32_chars_change_this
JWT_EXPIRE=30d

# ─── Email (Gmail SMTP with App Password) ────────────────────────────────────
# Generate a Gmail App Password at: https://myaccount.google.com/apppasswords
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# ─── Admin Bootstrap ──────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_secure_admin_password_min_8_chars

# ─── Frontend URL (used in email links) ───────────────────────────────────────
# Set to your production Vercel URL — no trailing slash
FRONTEND_URL=https://ever-active-physiotherapy.vercel.app

# ─── AI / OpenRouter (optional) ───────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-api-key
